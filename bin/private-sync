#!/usr/bin/env bash
#
# Sync ~/.config-private across machines. Runs from launchd (see
# io.d12frosted.private-sync.plist) and from eru's private task.
#
# Auto-synced content is limited to claude/memory: it is machine-generated,
# so there is nothing to review. Other private files (CLAUDE.md, etc.) are
# committed manually.

set -e

PRIVATE_CONFIG_HOME="${PRIVATE_CONFIG_HOME:-$HOME/.config-private}"
LOCK_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/private-sync/sync.lock"

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

# Surface actionable failures (e.g. rebase conflicts) so a broken sync
# does not stay silent. Routine, self-healing hiccups (offline fetch or
# push) are only logged, to avoid notification spam.
notify() {
  command -v terminal-notifier >/dev/null 2>&1 &&
    terminal-notifier -title "private-sync" -message "$1" >/dev/null 2>&1 || true
}

if [ ! -d "$PRIVATE_CONFIG_HOME/.git" ]; then
  log "No private config at $PRIVATE_CONFIG_HOME; nothing to sync"
  exit 0
fi

# Only one sync at a time. The launchd backstop, eru and manual runs all
# funnel through here; macOS has no flock(1), so use an atomic mkdir as
# the mutex and record the owner pid for staleness checks.
mkdir -p "$(dirname "$LOCK_DIR")"
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  lock_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
  if [ -n "$lock_pid" ]; then
    if kill -0 "$lock_pid" 2>/dev/null; then
      log "Another sync is running (pid $lock_pid); skipping"
      exit 0
    fi
    log "Stale lock (dead pid $lock_pid); taking over"
    rm -rf "$LOCK_DIR"; mkdir "$LOCK_DIR"
  elif [ -n "$(find "$LOCK_DIR" -maxdepth 0 -mmin +10 2>/dev/null)" ]; then
    log "Stale lock (no owner, older than 10m); taking over"
    rm -rf "$LOCK_DIR"; mkdir "$LOCK_DIR"
  else
    log "Lock held (acquiring elsewhere); skipping"
    exit 0
  fi
fi
echo $$ >"$LOCK_DIR/pid"
trap 'rm -rf "$LOCK_DIR"' EXIT

cd "$PRIVATE_CONFIG_HOME"

# Adopt Claude auto-memory directories that exist locally but are not in
# the repo yet: move them in and leave a symlink behind.
if [ -d "$HOME/.claude/projects" ]; then
  for project_dir in "$HOME/.claude/projects"/*/; do
    memory_dir="${project_dir%/}/memory"
    [ -d "$memory_dir" ] || continue
    [ -L "$memory_dir" ] && continue

    slug=$(basename "${project_dir%/}")
    repo_dir="$PRIVATE_CONFIG_HOME/claude/memory/$slug"
    if [ -e "$repo_dir" ]; then
      log "WARN: both $memory_dir and $repo_dir exist; resolve manually"
      continue
    fi

    log "Adopting Claude memory: $slug"
    mkdir -p "$PRIVATE_CONFIG_HOME/claude/memory"
    mv "$memory_dir" "$repo_dir"
    ln -s "$repo_dir" "$memory_dir"
  done
fi

if [ -n "$(git status --porcelain -- claude/memory)" ]; then
  git add claude/memory
  git commit -m "chore: sync claude memory from $(hostname -s)"
  log "Committed claude memory changes"
else
  log "Nothing to commit"
fi

log "Fetching from origin..."
if ! git fetch origin; then
  log "WARN: fetch failed (offline?); will retry next run"
  exit 0
fi

log "Rebasing on origin/master..."
if ! git rebase --autostash origin/master; then
  git rebase --abort || true
  log "ERROR: rebase conflict; manual resolution required"
  notify "sync paused: rebase conflict in $PRIVATE_CONFIG_HOME"
  exit 1
fi

# Link memory directories pulled from other machines so new knowledge is
# available locally without waiting for the next eru run.
if [ -d "$PRIVATE_CONFIG_HOME/claude/memory" ]; then
  for repo_dir in "$PRIVATE_CONFIG_HOME/claude/memory"/*/; do
    [ -d "$repo_dir" ] || continue
    slug=$(basename "${repo_dir%/}")
    target="$HOME/.claude/projects/$slug/memory"
    if [ ! -e "$target" ] && [ ! -L "$target" ]; then
      log "Linking Claude memory: $slug"
      mkdir -p "$(dirname "$target")"
      ln -s "${repo_dir%/}" "$target"
    fi
  done
fi

if [ -n "$(git log origin/master..master --oneline)" ]; then
  log "Pushing to origin..."
  if ! git push origin master; then
    log "WARN: push failed (offline?); will retry next run"
    exit 0
  fi
fi

log "Sync complete"
